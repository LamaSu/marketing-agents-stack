# ── Marketing Agents Stack — environment ─────────────────────────────
# Copy to .env and fill in. Bring your own Claude key; everything else is optional
# (the stack runs fully offline against bundled sample data with no connectors).

# ── Required: the model provider ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model routing (sane defaults; override per-agent if desired)
MODEL_REVIEWER=claude-opus-4-8              # claim-drift review: correctness matters
MODEL_REASONER=claude-sonnet-5             # account reasoning / copywriting
MODEL_CLASSIFIER=claude-haiku-4-5-20251001 # cheap signal classification / scoring assists

# ── Runtime ──────────────────────────────────────────────────────────
DATA_DIR=./.data                 # local warehouse + compounding memory (DuckDB/SQLite)
DRAFTS_DIR=./drafts              # draft-first: all external actions land here for human dispatch
LOG_LEVEL=info

# ── Optional connectors (leave blank to use bundled sample providers) ─
# Credentials are brokered via gatecraft when present — never read in plaintext by agents.
# CRM
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=
HUBSPOT_ACCESS_TOKEN=
# Signal / intent ingestion
POSTHOG_API_KEY=
POSTHOG_HOST=
# Enrichment (optional — the default enricher uses Claude + web search, no vendor key)
EXA_API_KEY=
CLEARBIT_API_KEY=
# Outbound (draft-first; sending is always human-gated)
RESEND_API_KEY=
SLACK_BOT_TOKEN=

# ── gatecraft credential broker (optional) ───────────────────────────
GATECRAFT_ENDPOINT=
